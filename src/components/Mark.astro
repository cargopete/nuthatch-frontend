---
// The nuthatch mark: head-down on a vertical trunk. Themes with the palette.
interface Props { size?: number; class?: string }
const { size = 28, class: cls = '' } = Astro.props;
---
<svg
  class={cls}
  width={size}
  height={size}
  viewBox="0 0 32 32"
  role="img"
  aria-label="Nuthatch"
  style="--body: var(--accent); --belly: var(--rust); display:block;"
>
  <rect x="5" y="3" width="3" height="26" rx="1.5" fill="var(--body)" />
  <polygon points="9,8 21,11 16,18 13,27 8,16" fill="var(--body)" />
  <polygon points="11,15 16,17 13,25" fill="var(--belly)" />
  <polygon points="11.6,25 14.4,25 13,30" fill="var(--belly)" />
</svg>
