---
// The nuthatch mark: a small bird in head-down descent — round head, swept
// wing, straight bill pointing down (nuthatches climb down trees headfirst).
// Themes with the palette.
interface Props { size?: number; class?: string }
const { size = 28, class: cls = '' } = Astro.props;
---
<svg
  class={cls}
  width={size}
  height={size}
  viewBox="0 0 64 64"
  role="img"
  aria-label="Nuthatch"
  style="--body: var(--accent); --bill: var(--rust); --eye: var(--bg); display:block;"
>
  <path
    d="M23 45 C15 45 11 36 16 29 C20 23 27 24 30 30 C34 24 44 16 55 9 C51 21 44 30 35 35 C39 37 44 37 48 35 C44 43 36 47 28 45 C27 48 25 50 22 51 Z"
    fill="var(--body)"
  />
  <path d="M20 44 L26 40 L13 53 Z" fill="var(--bill)" />
  <circle cx="22" cy="35" r="2.1" fill="var(--eye)" />
</svg>
