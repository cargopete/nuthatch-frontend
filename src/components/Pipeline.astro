---
// The data path, as a flow diagram. Horizontal on wide screens, stacking on
// mobile (the arrows rotate). Inline SVG arrow marks, palette-aware.
const stages = [
  { k: 'source',  t: 'chain',              s: 'RPC · reth ExEx' },
  { k: 'decode',  t: 'deterministic decode', s: 'topic0-keyed, versioned' },
  { k: 'views',   t: 'incremental views',  s: 'IVM · reorgs = retractions' },
  { k: 'store',   t: 'redb + Parquet',     s: 'hot tip · sealed segments' },
  { k: 'serve',   t: 'SQL · GraphQL · streams · MCP', s: 'one local endpoint' },
];
---
<ol class="pipe" aria-label="Nuthatch data path">
  {stages.map((st, i) => (
    <>
      <li class="pipe-node">
        <span class="pipe-title">{st.t}</span>
        <span class="pipe-sub">{st.s}</span>
      </li>
      {i < stages.length - 1 && (
        <li class="pipe-arrow" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 12h15" />
            <path d="M13 6l6 6-6 6" />
          </svg>
        </li>
      )}
    </>
  ))}
</ol>

<style>
  .pipe {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-wrap: wrap; align-items: stretch; gap: 0.5rem;
  }
  .pipe-node {
    flex: 1 1 0; min-width: 8.5rem;
    display: flex; flex-direction: column; justify-content: center; gap: 0.3rem;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem 1.05rem;
  }
  .pipe-title {
    font-family: 'JetBrains Mono', monospace; font-size: 0.82rem; font-weight: 500;
    color: var(--text); letter-spacing: -0.01em; line-height: 1.35;
  }
  .pipe-sub { font-size: 0.72rem; color: var(--text-faint); font-family: 'JetBrains Mono', monospace; }
  .pipe-arrow {
    flex: 0 0 auto; display: flex; align-items: center; justify-content: center;
    color: var(--text-faint);
  }
  .pipe-node:last-of-type { border-color: var(--border-hi); }

  @media (max-width: 46rem) {
    .pipe { flex-direction: column; align-items: stretch; }
    .pipe-arrow { transform: rotate(90deg); padding-block: 0.15rem; align-self: center; }
    .pipe-node { min-width: 0; }
  }
</style>
