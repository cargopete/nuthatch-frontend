---
import { Code } from 'astro:components';
// Multi-line code block with build-time Shiki highlighting (no client-side
// highlighter) and a copy button (bound by the shared handler in Layout).
// Dual-theme via CSS variables so the site's :has() toggle drives it.
interface Props {
  code: string;
  lang?: string;
  label?: string;
}
const { code, lang = 'sql', label } = Astro.props;
---
<figure class="codecard">
  <div class="codecard-top">
    {label && <figcaption class="codecard-label">{label}</figcaption>}
    <button class="copyblock-btn codecard-copy" type="button" data-copy={code} aria-label="Copy code">
      <span class="copyblock-btn-label">copy</span>
    </button>
  </div>
  <Code
    code={code}
    lang={lang}
    themes={{ light: 'vitesse-light', dark: 'vitesse-dark' }}
    defaultColor={false}
  />
</figure>

<style>
  .codecard {
    margin: 0 0 1.4rem;
    background: var(--bg-code);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .codecard-top {
    display: flex; align-items: center; justify-content: space-between; gap: 0.5rem;
    padding: 0.5rem 0.6rem 0.5rem 1rem;
    border-bottom: 1px solid var(--border);
    min-height: 2.4rem;
  }
  .codecard-label {
    font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--text-faint);
  }
  .codecard-copy { flex-shrink: 0; margin-left: auto; }
</style>
